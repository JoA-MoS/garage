PORT=3334
NODE_ENV=development
FRONTEND_URL=http://localhost:8081

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASS=postgres
DB_NAME=sift
# WARNING: Never set to true in production. Use migrations instead.
DB_SYNCHRONIZE=false

# Encryption key for OAuth tokens at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# AI
ANTHROPIC_API_KEY=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3334/api/auth/google/callback

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=7d
