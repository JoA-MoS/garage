PORT=3334
NODE_ENV=development
FRONTEND_URL=http://localhost:8081

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASS=postgres
DB_NAME=sift
# true for local dev only — no migrations exist yet
DB_SYNCHRONIZE=true

# Encryption key for OAuth tokens at rest
ENCRYPTION_KEY=local-dev-encryption-key-replace-before-any-real-data

# AI
ANTHROPIC_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3334/api/auth/google/callback

# JWT
JWT_SECRET=local-dev-jwt-secret-replace-before-any-real-data
JWT_EXPIRES_IN=7d
