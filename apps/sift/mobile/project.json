{
  "name": "sift-mobile",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/sift/mobile",
  "projectType": "application",
  "tags": ["type:app", "domain:sift"],
  "targets": {
    "start": {
      "executor": "@nx/expo:start",
      "dependsOn": ["sift-api:serve", "sync-deps"],
      "options": {
        "port": 8082
      }
    },
    "serve": {
      "executor": "@nx/expo:serve",
      "dependsOn": ["sift-api:serve", "sync-deps"],
      "options": {
        "port": 8082
      }
    },
    "run-ios": {
      "executor": "@nx/expo:run",
      "dependsOn": ["sync-deps"],
      "options": {
        "platform": "ios"
      }
    },
    "run-android": {
      "executor": "@nx/expo:run",
      "dependsOn": ["sync-deps"],
      "options": {
        "platform": "android"
      }
    },
    "build": {
      "executor": "@nx/expo:build",
      "dependsOn": ["sync-deps"],
      "options": {}
    },
    "submit": {
      "executor": "@nx/expo:submit",
      "options": {}
    },
    "build-list": {
      "executor": "@nx/expo:build-list",
      "options": {}
    },
    "sync-deps": {
      "executor": "@nx/expo:sync-deps",
      "options": {}
    },
    "prebuild": {
      "executor": "@nx/expo:prebuild",
      "dependsOn": ["sync-deps"],
      "options": {}
    },
    "install": {
      "executor": "@nx/expo:install",
      "options": {}
    },
    "update": {
      "executor": "@nx/expo:update",
      "options": {}
    },
    "export": {
      "executor": "@nx/expo:export",
      "dependsOn": ["sync-deps"],
      "outputs": ["{options.outputDir}"],
      "options": {
        "platform": "all",
        "outputDir": "apps/sift/mobile/dist"
      }
    },
    "ensure-symlink": {
      "executor": "@nx/expo:ensure-symlink",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
